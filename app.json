{
  "expo": {
    "name": "リタス",
    "slug": "litus",
    "version": "1.0.0",
    "scheme": "litus",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.waiteu.litus"
    },
    "android": {
      "package": "dev.waiteu.litus",
      "versionCode": 91,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#0f1713"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false
          }
        }
      ],
      "expo-font",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "LitusToday",
              "label": "リタス: 今日の授業",
              "description": "次の授業・後続コマ・直近の課題",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "LitusNext",
              "label": "リタス: 次の授業",
              "description": "次の授業と残り時間",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "resizeMode": "none",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "a707ca3f-a0c4-4a9a-8967-733b76c4c38a"
      }
    }
  }
}
